FROM python:3.12-slim

WORKDIR /app

# 配置 pip 使用阿里云镜像（国内服务器加速）
RUN pip config set global.index-url https://mirrors.aliyun.com/pypi/simple/ \
    && pip config set global.trusted-host mirrors.aliyun.com

# 安装系统依赖
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    git \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# 先安装后端专用依赖（变化少，利用缓存）
COPY backend/requirements-api.txt ./backend/requirements-api.txt
RUN pip install --no-cache-dir --retries 5 --timeout 120 -r backend/requirements-api.txt

# 安装中文字体（解决 matplotlib/ezdxf 中文渲染问题）
RUN apt-get update && apt-get install -y fonts-wqy-microhei && rm -rf /var/lib/apt/lists/*

# 单独安装 OpenManus（从本地 vendor 目录安装，无需网络）
# 用 --no-deps 安装包本身，再手动补齐所有运行时依赖（跳过 playwright/browsergym 等浏览器自动化重型依赖）
COPY vendor/OpenManus /tmp/OpenManus
RUN pip install --no-cache-dir --no-deps /tmp/OpenManus \
    && pip install --no-cache-dir \
        "pydantic~=2.10.4" \
        "pydantic_core>=2.27.2,<2.28.0" \
        "openai>=1.58.1,<1.67.0" \
        "tenacity~=9.0.0" \
        "loguru~=0.7.3" \
        "html2text~=2024.2.26" \
        "uvicorn~=0.34.0" \
        "unidiff~=0.7.5" \
        "aiofiles~=24.1.0" \
        "colorama~=0.4.6" \
        "tiktoken>=0.7.0" \
        "boto3>=1.34.0" \
        "docker~=7.1.0" \
        "structlog~=24.1.0" \
        "browser-use~=0.1.40" \
        "pyee>=11.0.0" \
        "pyyaml~=6.0.2" \
        "baidusearch~=1.0.3" \
        "googlesearch-python~=1.3.0" \
        "duckduckgo_search~=7.5.3" \
        "mcp~=1.5.0" \
        "httpx>=0.27.0" \
        "tomli>=2.0.0" \
        "requests~=2.32.3" \
        "beautifulsoup4~=4.13.3" \
        "huggingface-hub~=0.29.2" \
    && rm -rf /tmp/OpenManus

# 为 OpenManus 创建最小配置文件（仅用于通过初始化检查，实际 API key 由用户动态注入）
RUN mkdir -p /usr/local/lib/python3.12/site-packages/config && \
    printf '[llm]\nmodel = "deepseek-chat"\nbase_url = "https://api.deepseek.com/v1"\napi_key = "placeholder"\nmax_tokens = 4000\ntemperature = 0.7\n\n[llm.vision]\nmodel = "deepseek-chat"\nbase_url = "https://api.deepseek.com/v1"\napi_key = "placeholder"\nmax_tokens = 4000\ntemperature = 0.7\n\n[mcp]\nserver_reference = "app.mcp.server"\n\n[daytona]\ndaytona_api_key = "placeholder"\n' \
    > /usr/local/lib/python3.12/site-packages/config/config.toml

# 安装其余核心依赖
COPY requirements.txt ./requirements.txt
RUN pip install --no-cache-dir --retries 5 --timeout 120 -r requirements.txt

# 复制项目代码
COPY . .

# 创建输出目录，预构建 ezdxf 字体缓存（包含 wqy-microhei.ttc）
RUN mkdir -p output/drawings output/reports output/visualizations logs \
    && python3 -c "import ezdxf.fonts.fonts as f; f.build_font_manager_cache(f._get_font_manager_path()); print('ezdxf font cache built')"

EXPOSE 8000

CMD ["uvicorn", "backend.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
